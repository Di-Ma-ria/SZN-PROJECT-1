# *SERVER*
PORT=6000
# PORT //any four digits value of your choice
NODE_ENV=development
FRONTEND_URL=http://localhost:1352
BACKEND_URL=http://localhost:6000
# *DATABASE*
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
# *JWT*
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=10m
JWT_REFRESH_SECRET= your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=your_cookie_secret
# *EMAIL(NODEMAILER/HTTPS)*
EMAIL_FROM_NAME=yourstorename
EMAIL_FROM=SZN Store <noreply@yourstore.com>
BREVO_API_KEY=your brevo api key
# *CLOUDINARY*
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# *PAYSTACK*
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxx
# *SUPERADMIN SEED*
SUPERADMIN_NAME=superadmin
SUPERADMIN_EMAIL=superadmin@yourstore.com
SUPERADMIN_PASSWORD=supersecurepassword
SUPERADMIN_PHONE=+234012345678
SUPERADMIN_STREET=1 Admin Street
SUPERADMIN_CITY=Lagos
SUPERADMIN_STATE=Lagos
SUPERADMIN_COUNTRY=Nigeria


